# ─────────────────────────────────────────────────────────────────────────────
# CD-WEB-BE — Biến môi trường mẫu (copy thành .env, KHÔNG commit .env lên Git)
# Spring Boot đọc qua application.yml: ${VAR:default}
# ─────────────────────────────────────────────────────────────────────────────

# Database (hoặc cấu hình trực tiếp trong application.yml)
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/cd_web
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=

# JWT — bắt buộc đổi trên môi trường production (≥ 64 ký tự ngẫu nhiên)
JWT_SECRET=your_secret_key_here_change_this_to_a_long_random_string_at_least_64_chars

# URL ứng dụng
APP_FRONTEND_URL=http://localhost:3000
APP_BACKEND_URL=http://localhost:8080

# Email (quên mật khẩu)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# VNPay (sandbox)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# GHN (sandbox)
GHN_TOKEN=
GHN_SHOP_ID=

# AI gợi ý sản phẩm (tùy chọn)
AI_SERVICE_BASE_URL=http://localhost:5000

# Google OAuth2 — Cấu Hình Chuyên Đề Web (cùng Client ID với FE)
GOOGLE_CLIENT_ID=91702937442-68dtl399821hm38ur4pnnsqmuhrj555i.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
